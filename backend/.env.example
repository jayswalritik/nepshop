# ─────────────────────────────────────────
# NepShop Backend — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to Git
# ─────────────────────────────────────────

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/nepshop?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/nepshop?retryWrites=true&w=majority

# JWT secret — use a long random string in production
JWT_SECRET=nepshop_super_secret_jwt_key_change_this_in_production

# JWT expiry
JWT_EXPIRES_IN=7d

# Server port
PORT=5000

# Environment
NODE_ENV=development

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000
